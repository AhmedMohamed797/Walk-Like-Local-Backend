PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/walk-like-local
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# Brevo SMTP (https://www.brevo.com/)
BREVO_SMTP_USER=your-brevo-login-email
BREVO_SMTP_KEY=your-brevo-smtp-key
EMAIL_FROM=noreply@yourdomain.com

# Google OAuth (https://www.passportjs.org/packages/passport-google-oauth2/)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary (https://cloudinary.com/)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Groq — chat, TTS & transcription (https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key
# One-time setup: accept Orpheus TTS terms in the Groq console before spoken questions work:
# https://console.groq.com/playground?model=canopylabs%2Forpheus-v1-english

# Stripe (https://stripe.com/)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
